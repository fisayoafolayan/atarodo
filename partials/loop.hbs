<article class="post-card {{post_class}}">
    <div class="post-card-content">
        <h2 class="post-card-title"><a href="{{url}}">{{title}}</a></h2>
        <span class="post-card-meta">
            By <a href="{{authors.[0].url}}">{{authors.[0].name}}</a>
            {{#if primary_tag}}
                in <a class="post-card-meta-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            on <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
        </span>
        <p class="post-card-excerpt">{{excerpt words="60"}}&hellip;</p>
    </div>
</article>
