{{!< default}}

<article class="error-page">
    <span class="error-code">{{statusCode}}</span>
    <h1 class="error-title">{{#match statusCode 404}}Lost in the sauce{{else}}The server is having a moment{{/match}}</h1>
    <p class="error-message">{{#match statusCode 404}}Looks like this page took a vacation without telling anyone.{{else}}{{message}}{{/match}}</p>
    <div class="error-actions">
        <a class="error-link" href="{{@site.url}}">Go to homepage</a>
        <a class="error-link error-link-secondary" href="#" onclick="history.back();return false;">Go back</a>
    </div>
</article>
