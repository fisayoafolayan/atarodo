{{!< default}}

<article class="error-page">
    <span class="error-code">{{statusCode}}</span>
    <h1 class="error-title">{{#is "404"}}Page not found{{else}}Something went wrong{{/is}}</h1>
    <p class="error-message">{{#is "404"}}The page you're looking for doesn't exist or has been moved.{{else}}{{message}}{{/is}}</p>
    <div class="error-actions">
        <a class="error-link" href="{{@site.url}}">Go to homepage</a>
        <a class="error-link error-link-secondary" href="#" onclick="history.back();return false;">Go back</a>
    </div>
</article>
