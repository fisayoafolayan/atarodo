{
  "name": "atarodo",
  "description": "A minimal, content-focused Ghost theme",
  "version": "1.0.5",
  "license": "MIT",
  "author": {
    "name": "Fisayo Afolayan",
    "email": "afolayan@pm.me"
  },
  "keywords": [
    "ghost-theme",
    "minimal",
    "blog"
  ],
  "engines": {
    "ghost": ">=6.0.0"
  },
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xs": {
        "width": 300
      },
      "s": {
        "width": 600
      },
      "m": {
        "width": 1000
      },
      "l": {
        "width": 1600
      },
      "xl": {
        "width": 2000
      }
    },
    "card_assets": true
  },
  "scripts": {
    "build": "npm run css && npm run js",
    "css": "lightningcss --minify --bundle assets/css/style.css -o assets/css/style.min.css",
    "js": "terser assets/js/script.js -o assets/js/script.min.js -c -m",
    "zip": "npm run build && zip -r atarodo.zip assets partials *.hbs package.json LICENSE README.md -x 'assets/css/style.css' 'assets/js/script.js'",
    "dev": "docker compose up",
    "lint": "npx gscan .",
    "prezip": "npm run lint"
  },
  "devDependencies": {
    "lightningcss-cli": "^1.32.0",
    "terser": "^5.46.1"
  }
}
