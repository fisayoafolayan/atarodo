{{!< default}}

<div class="archive-header">
    {{#if profile_image}}
        <img class="archive-author-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
    {{/if}}
    <h1 class="archive-title">{{name}}</h1>
    {{#if bio}}
        <p class="archive-description">{{bio}}</p>
    {{/if}}
</div>

<div class="post-feed">
    {{#foreach posts}}
        {{> loop}}
    {{/foreach}}
</div>

{{> pagination}}
