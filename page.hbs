{{!< default}}

{{#post}}
<div class="page-main">
    <article class="post post-full page {{post_class}}">
        {{#if @page.show_title_and_feature_image}}
            {{#if feature_image}}
                <figure class="page-cover">
                    <img
                        srcset="{{img_url feature_image size="s"}} 300w,
                                {{img_url feature_image size="m"}} 1000w,
                                {{img_url feature_image size="l"}} 1600w"
                        sizes="(max-width: 700px) 300px, (max-width: 1100px) 1000px, 1600px"
                        src="{{img_url feature_image size="l"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    >
                </figure>
            {{/if}}

            <header class="page-header">
                <h1 class="page-title">{{title}}</h1>
            </header>
        {{/if}}

        <section class="post-content">
            {{content}}
        </section>
    </article>
</div>
{{/post}}
